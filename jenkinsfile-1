pipeline {
    agent any

    tools {
        maven 'Maven-3.9.15'
    }

    stages {

        stage('checkout') {
            steps {
                cleanWs()
                echo 'cloning repo'
                git 'https://github.com/lizdevops/DevOpsClassCodes-aug.git'
            }
        }

        stage('compile') {
            steps {
                sh 'mvn compile'
            }
        }

        stage('test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('package') {
            steps {
                sh 'mvn package'
                sh 'ls target'
            }
        }

        stage('docker build') {
            steps {
                sh 'docker version'
                sh 'docker build -t lizholly1/addressbook .'
            }
        }

        stage('docker login') {
            steps {
                sh 'echo lizdocker1 | docker login -u lizholly1 --password-stdin'
            }
        }

        stage('docker push') {
            steps {
                sh 'docker push lizholly1/addressbook'
            }
        }
    }
}