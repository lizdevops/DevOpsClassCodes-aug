pipeline {
    agent any

    tools {
        maven 'Maven-3.9.15'
    }

    stages {
        stage('checkout') {
            steps {
                echo 'i am doin a git clone'
                git 'https://github.com/lizdevops/DevOpsClassCodes-aug.git'
            }
        }

        stage('compile') {
            steps {
                sh 'mvn compile'
            }
        }

        stage('test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('docker build') {
            steps {
                sh 'docker build -t lizholly1/addressbook .'
            }
        }

        stage('docker login') {
            steps {
                sh 'docker login -u lizholly1 -p lizdocker1'
            }
        }

        stage('docker push') {
            steps {
                sh 'docker push lizholly1/addressbook'
            }
        }
    }
}